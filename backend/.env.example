# ============================================================
# WIZONE LMS - Environment Variables
# Copy this to .env and fill in your values
# ============================================================

NODE_ENV=development
PORT=5000

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── MSSQL ────────────────────────────────────────────────────
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=WizoneLMS
DB_USER=sa
DB_PASSWORD=YourStrong@Password
DB_ENCRYPT=false
DB_TRUST_SERVER_CERT=true

# ── Redis (for BullMQ job queues) ────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Frontend URL (for CORS) ───────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Meta / Facebook ──────────────────────────────────────────
META_APP_SECRET=your_meta_app_secret
META_VERIFY_TOKEN=your_custom_verify_token_for_webhook
META_PAGE_ACCESS_TOKEN=your_page_access_token
META_WHATSAPP_PHONE_ID=your_whatsapp_business_phone_id

# ── Email (Nodemailer / SMTP) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Wizone <no-reply@wizone.com>

# ── WhatsApp (Twilio) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Telegram Bot ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_admin_telegram_chat_id

# ── Interakt (Alternative WhatsApp) ───────────────────────────
INTERAKT_API_KEY=your_interakt_api_key

# ── Company Info (used in message templates) ──────────────────
COMPANY_NAME=Wizone
COMPANY_WEBSITE=https://wizone.com
COMPANY_PHONE=+91XXXXXXXXXX
